ENVIRONMENT=production

# Comma-separated list of frontend origins allowed to call this API
CORS_ORIGINS=https://your-frontend.vercel.app,http://localhost:3000

# Where temp downloads are stored before being streamed to the client
DOWNLOAD_DIR=/tmp/fetchly-downloads
JOB_TTL_SECONDS=1800

# Abuse / resource protection
MAX_VIDEO_DURATION_SECONDS=14400
MAX_CONCURRENT_JOBS_PER_IP=3
MAX_CONCURRENT_JOBS_GLOBAL=20
RATE_LIMIT_REQUESTS_PER_MINUTE=20

# Optional — only set this if videos start failing with "Sign in to
# confirm you're not a bot" even after the built-in player_client
# fallback. Path to a cookies.txt file exported from a logged-in
# browser session. See README's Troubleshooting section.
COOKIES_FILE=
